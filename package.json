{
  "name": "@ivosabev/helpers",
  "version": "1.0.4",
  "description": "Reusable Helpers",
  "keywords": [
    "ecmascript",
    "helpers",
    "javascript",
    "typescript",
    "utility functions"
  ],
  "homepage": "https://github.com/ivosabev/helpers#readme",
  "bugs": {
    "url": "https://github.com/ivosabev/helpers/issues"
  },
  "license": "MIT",
  "author": "Ivo Sabev (http://ivosabev.com/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ivosabev/helpers.git"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./*": "./*.js"
  },
  "scripts": {
    "build": "npm run validate && rm -rf dist && run-p -l build-js build-dts && scripts/afterBuild.sh",
    "build-js": "esbuild src/**/*.ts --outdir=dist --format=esm --sourcemap --target=es2023",
    "build-dts": "tsgo -p tsconfig.build.json --declaration --emitDeclarationOnly --noEmit false --rootDir src --outDir dist",
    "format": "oxfmt",
    "format-check": "oxfmt --check",
    "lint": "oxlint",
    "lint-check": "oxlint",
    "release-it": "release-it",
    "release": "scripts/release.sh",
    "typecheck": "tsgo",
    "up": "corepack use pnpm@latest && pnpm update --interactive --latest",
    "validate": "run-p -l lint format typecheck",
    "watch": "npm run build && watchman-make -p 'src/**/*' --run 'npm run build'"
  },
  "dependencies": {
    "@web3-storage/multipart-parser": "1.0.0",
    "chardet": "2.1.1",
    "crypto-js": "4.2.0",
    "fuzzysort": "3.1.0",
    "lodash": "4.18.1",
    "luxon": "3.7.2",
    "object-hash": "3.0.0",
    "papaparse": "5.5.3",
    "pluralize": "8.0.0",
    "type-fest": "5.5.0",
    "validator": "13.15.35"
  },
  "devDependencies": {
    "@graphql-tools/utils": "11.0.1",
    "@ivosabev/config": "4.0.3",
    "@types/crypto-js": "4.2.2",
    "@types/lodash": "4.17.24",
    "@types/luxon": "3.7.1",
    "@types/node": "25.6.0",
    "@types/object-hash": "3.0.6",
    "@types/papaparse": "5.5.2",
    "@types/pluralize": "0.0.33",
    "@types/react": "19.2.14",
    "@types/validator": "13.15.10",
    "@typescript/native-preview": "7.0.0-dev.20260413.1",
    "esbuild": "0.28.0",
    "graphql": "16.13.2",
    "graphql-relay": "0.10.2",
    "npm-run-all": "4.1.5",
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "oxlint-tsgolint": "0.20.0",
    "react": "19.2.5",
    "release-it": "19.2.4",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@graphql-tools/utils": "10.x",
    "graphql": "16.x",
    "graphql-relay": "0.10.2",
    "react": "18.x || 19.x",
    "zod": "4.x"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
